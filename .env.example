# Environment Variables
# Copy this file to apps/api/.env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/iam_human

# Secret key for JWT signing (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Admin console password
ADMIN_PASSWORD=change-me-admin-password

# API base URL used by the web console
VITE_API_URL=http://localhost:3001
